import { useBrowserVisibleTask$ } from "@qwik.dev/core";
import { useStore } from "@qwik.dev/core";
export const _u6BtPnK76q4 = () => {
	const state = useStore({
		count: 0
	});

	// Double count watch
	useBrowserVisibleTask$(() => {
		const timer = setInterval(() => {
		state.count++;
		}, 1000);
		return () => {
		clearInterval(timer);
		}
	});

	return (
		<div>
		{state.count}
	</div>
	);
};
