import { RecursiveList } from "./test";
export const RecursiveList_component_ignTe6QguYQ = (props) => {
	if (props.depth === 0) return <div>End</div>;
	return (
		<div>
			Level {props.depth}
			<RecursiveList depth={props.depth - 1} />
		</div>
	);
};
