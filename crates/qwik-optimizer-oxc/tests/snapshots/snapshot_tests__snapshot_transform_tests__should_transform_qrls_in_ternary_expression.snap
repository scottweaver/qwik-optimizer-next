import { $ } from "@qwik.dev/core";
import { useSignal } from "@qwik.dev/core";
export const _u6BtPnK76q4 = () => {
	const enabled = useSignal(false);
	const input = useSignal("");

  return (
     <input
		id="input"
		onInput$={
		enabled.value
			? $((ev, el) => {
				input.value = el.value;
			})
			: undefined
		}
		onFocus$={() => {
			enabled.value = true;
		}}
	/>
  );
};
