import { componentQrl } from "@qwik.dev/core";
import { useTaskQrl } from "@qwik.dev/core";
import { CONST } from "const";
export const Works = componentQrl(({ count, some = 1 + 2, hello = CONST, stuff: hey, stuffDefault: hey2 = 123, ...rest }) => {
	console.log(hey, some);
	useTaskQrl(({ track }) => {
		track(() => count);
		console.log(count, rest, hey, some, hey2);
	}, "Works_component_useTask_pjo5U5Ikll0", [
		count,
		hey,
		hey2,
		rest,
		some
	]);
	return _jsxSplit("div", {
		some,
		params: { some },
		class: count,
		...rest
	}, { override: true }, count, 1, null);
}, "Works_component_t45qL4vNGv0");
export const NoWorks2 = componentQrl(({ count, stuff: { hey } }) => {
	console.log(hey);
	useTaskQrl(({ track }) => {
		track(() => count);
		console.log(count);
	}, "NoWorks2_component_useTask_lXiqwbxxjq0", [count]);
	return _jsxSorted("div", { class: count }, null, count, 1, null);
}, "NoWorks2_component_JPD9t2HyEKg");
