import { default as mongo } from "mongodb";
import { useStore } from "@qwik.dev/core";
import { useTask$ } from "@qwik.dev/core";
export const Child_7e7u5mtQ0PI = () => {
	const state = useStore({
		text: ''
	});

	// Double count watch
	useTask$(async () => {
		state.text = await mongo.users();
	});

	return (
		<div onClick$={() => console.log('child')}>
			{state.text}
		</div>
	);
};
